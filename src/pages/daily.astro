---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Daily Card Draw | The Hermetic Flight"
  description="See today's aerial tarot card — a new card every day, the same for everyone. Interpretation, journaling prompt, and share button."
  ogImage="/images/og/daily.png"
>
  <main class="w-full min-h-screen flex flex-col items-center relative z-10 pt-6 pb-16 px-4">

    <!-- Minimal Header -->
    <header class="w-full py-4 flex justify-center mb-4">
      <a href="/" class="group flex items-center gap-3">
        <img src="/images/logo.png" alt="The Hermetic Flight"
          class="w-10 h-10 rounded-full opacity-80 group-hover:opacity-100 transition-opacity" />
        <span class="font-serif text-hermetic-gold/60 text-sm tracking-[0.2em] uppercase group-hover:text-hermetic-gold transition-colors">
          The Hermetic Flight
        </span>
      </a>
    </header>

    <!-- Hero -->
    <div class="w-full max-w-2xl text-center mb-8">
      <p class="text-hermetic-gold text-xs tracking-[0.3em] uppercase font-sans mb-3">Aerial Tarot</p>
      <h1 class="font-serif text-3xl md:text-4xl text-hermetic-white mb-2 tracking-wide">Today's Card</h1>
      <p id="daily-date" class="text-gray-500 font-sans text-sm tracking-wide">Loading...</p>
    </div>

    <!-- Card Panel -->
    <div class="w-full max-w-2xl">
      <div class="glass-panel p-8 md:p-12 rounded-lg text-center relative">
        <!-- Corner accents -->
        <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-hermetic-gold opacity-50"></div>
        <div class="absolute top-2 right-2 w-3 h-3 border-t border-r border-hermetic-gold opacity-50"></div>
        <div class="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-hermetic-gold opacity-50"></div>
        <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-hermetic-gold opacity-50"></div>

        <!-- Radial gold glow -->
        <div class="absolute top-0 left-0 w-full h-full rounded-lg pointer-events-none" style="background: radial-gradient(circle at 50% 30%, #C5A05920 0%, transparent 60%);"></div>

        <div class="relative">
          <!-- Card label -->
          <p id="card-label" class="text-hermetic-gold text-xs tracking-[0.3em] uppercase font-sans mb-4 opacity-0 transition-opacity duration-700">
            Card of the Day
          </p>

          <!-- Card flip container -->
          <div class="flex justify-center mb-6">
            <div id="card-container" style="perspective: 1000px; width: 12rem; height: 18rem; cursor: default;">
              <div id="card-inner" style="position: relative; width: 100%; height: 100%; transform-style: preserve-3d; transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);">
                <!-- Card back face -->
                <div style="position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden;">
                  <img
                    id="card-back-img"
                    src="/images/cards/card-back.png"
                    alt="Card back"
                    class="w-full h-full object-cover rounded-lg border border-hermetic-gold/30 shadow-deep-glass"
                  />
                </div>
                <!-- Card front face -->
                <div style="position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; transform: rotateY(180deg);">
                  <img
                    id="card-front-img"
                    src="/images/cards/card-back.png"
                    alt="Today's aerial tarot card"
                    class="w-full h-full object-cover rounded-lg border border-hermetic-gold/30 shadow-deep-glass"
                  />
                </div>
              </div>
            </div>
          </div>

          <!-- Tap hint (post-reveal only) -->
          <p id="flip-hint" class="text-hermetic-gold/40 text-xs font-sans tracking-wider mb-4 hidden">
            Tap card to reveal
          </p>

          <!-- Card name -->
          <h2 id="card-name" class="font-serif text-2xl md:text-3xl text-hermetic-white mb-4 tracking-wide opacity-0 transition-opacity duration-700">
            Loading...
          </h2>

          <div class="w-16 h-[1px] bg-gradient-to-r from-transparent via-hermetic-gold/60 to-transparent mx-auto mb-6"></div>

          <!-- Card meaning -->
          <p id="card-meaning" class="text-gray-300 font-light font-sans leading-relaxed mb-6 max-w-lg mx-auto opacity-0 transition-opacity duration-700">
          </p>

          <!-- Aerial connection -->
          <div id="aerial-connection-block" class="mb-6 opacity-0 transition-opacity duration-700">
            <p class="text-hermetic-gold text-xs tracking-[0.2em] uppercase font-sans mb-2">Aerial Connection</p>
            <p id="aerial-connection-text" class="text-gray-400 font-light italic font-sans leading-relaxed max-w-lg mx-auto">
            </p>
          </div>

          <!-- Journaling prompt -->
          <div id="journaling-block" class="opacity-0 transition-opacity duration-700 mb-8">
            <div class="glass-panel rounded-lg p-6 md:p-8 text-left">
              <p class="text-hermetic-gold text-xs tracking-[0.2em] uppercase font-sans mb-3">Journaling Prompt</p>
              <p id="journaling-text" class="font-serif text-lg text-hermetic-white/90 leading-relaxed italic">
              </p>
            </div>
          </div>

          <!-- Share section -->
          <div id="share-section" class="border-t border-hermetic-gold/20 pt-8 mt-8 opacity-0 transition-opacity duration-700">
            <p class="text-hermetic-gold/60 text-xs tracking-[0.2em] uppercase font-sans mb-4">Share Today's Card</p>
            <div id="share-buttons" class="flex justify-center gap-3 flex-wrap">
              <a id="share-x" href="#" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 border border-hermetic-gold/30 rounded-lg text-hermetic-gold/80 hover:text-hermetic-gold hover:border-hermetic-gold/60 transition-colors text-sm font-sans">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                Post
              </a>
              <a id="share-fb" href="#" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 border border-hermetic-gold/30 rounded-lg text-hermetic-gold/80 hover:text-hermetic-gold hover:border-hermetic-gold/60 transition-colors text-sm font-sans">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Share
              </a>
              <button id="share-copy"
                class="inline-flex items-center gap-2 px-4 py-2 border border-hermetic-gold/30 rounded-lg text-hermetic-gold/80 hover:text-hermetic-gold hover:border-hermetic-gold/60 transition-colors text-sm font-sans">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
                <span id="share-copy-text">Copy Link</span>
              </button>
            </div>

            <!-- CTA -->
            <div class="border-t border-hermetic-gold/20 pt-8 mt-8">
              <p class="text-hermetic-white font-serif text-lg mb-2">Discover Your Aerial Tarot Archetype</p>
              <p class="text-gray-400 font-sans text-sm mb-6">Twenty questions. Five minutes. One revelation.</p>
              <a href="/quiz" class="btn-flame inline-block px-8 py-3 text-white font-sans font-bold text-sm tracking-widest uppercase no-underline">
                Take the Quiz
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>

  <script>
    import { getDailyCard } from '../lib/daily-draw';
    import type { CardData } from '../lib/card-data';

    const REVEAL_DATE = new Date('2026-06-07T00:00:00Z');
    const today = new Date();
    const isRevealed = today >= REVEAL_DATE;
    const dateStr = today.toISOString().slice(0, 10);

    const card: CardData = getDailyCard(today);

    // --- DOM refs ---
    const dateLabel       = document.getElementById('daily-date')!;
    const cardLabel       = document.getElementById('card-label')!;
    const cardName        = document.getElementById('card-name')!;
    const cardMeaning     = document.getElementById('card-meaning')!;
    const aerialBlock     = document.getElementById('aerial-connection-block')!;
    const aerialText      = document.getElementById('aerial-connection-text')!;
    const journalingBlock = document.getElementById('journaling-block')!;
    const journalingText  = document.getElementById('journaling-text')!;
    const shareSection    = document.getElementById('share-section')!;
    const flipHint        = document.getElementById('flip-hint')!;
    const cardContainer   = document.getElementById('card-container')!;
    const cardInner       = document.getElementById('card-inner')!;
    const cardFrontImg    = document.getElementById('card-front-img') as HTMLImageElement;
    const shareX          = document.getElementById('share-x') as HTMLAnchorElement;
    const shareFb         = document.getElementById('share-fb') as HTMLAnchorElement;
    const shareCopy       = document.getElementById('share-copy')!;
    const shareCopyText   = document.getElementById('share-copy-text')!;

    // --- Populate date ---
    dateLabel.textContent = today.toLocaleDateString('en-US', {
      weekday: 'long',
      year:    'numeric',
      month:   'long',
      day:     'numeric',
    });

    // --- Populate card content ---
    cardName.textContent        = card.name;
    cardMeaning.textContent     = card.meaning;
    aerialText.textContent      = card.aerialConnection;
    journalingText.textContent  = card.journalingPrompt;

    // --- Card flip setup ---
    if (isRevealed && card.artReady) {
      cardFrontImg.src = `/images/cards/${card.slug}.png`;
      cardFrontImg.alt = card.name;
      cardContainer.style.cursor = 'pointer';
      flipHint.classList.remove('hidden');

      let flipped = false;
      cardContainer.addEventListener('click', () => {
        flipped = !flipped;
        cardInner.style.transform = flipped ? 'rotateY(180deg)' : '';
        flipHint.textContent = flipped ? 'Tap to flip back' : 'Tap card to reveal';
      });
    }
    // Pre-reveal: card-back stays visible, no flip interaction

    // --- Staggered content reveal ---
    function showEl(el: HTMLElement) {
      el.style.opacity = '1';
    }

    setTimeout(() => showEl(cardLabel),       50);
    setTimeout(() => showEl(cardName),        100);
    setTimeout(() => showEl(cardMeaning),     300);
    setTimeout(() => showEl(aerialBlock),     500);
    setTimeout(() => showEl(journalingBlock), 700);
    setTimeout(() => showEl(shareSection),    900);

    // --- Share URLs ---
    const pageUrl   = 'https://www.thehermeticflight.com/daily';
    const shareText = `Today's aerial tarot card is ${card.name}. What does the sky have to say? Discover your daily draw:`;

    shareX.href  = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}`;
    shareFb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;

    shareCopy.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(pageUrl);
        shareCopyText.textContent = 'Copied!';
      } catch {
        shareCopyText.textContent = 'Copy failed';
      }
      setTimeout(() => { shareCopyText.textContent = 'Copy Link'; }, 2000);
    });

    // --- Share tracking via event delegation ---
    const shareButtons = document.getElementById('share-buttons')!;
    shareButtons.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest('a, button') as HTMLElement | null;
      if (!target) return;

      let platform: string | null = null;
      if (target === shareX)    platform = 'x';
      else if (target === shareFb)   platform = 'facebook';
      else if (target === shareCopy) platform = 'copy_link';

      if (platform && typeof gtag === 'function') {
        gtag('event', 'share', {
          method:       platform,
          content_type: 'daily_card',
          item_id:      card.name,
        });
      }
    });

    // --- GA4 page view event ---
    if (typeof gtag === 'function') {
      gtag('event', 'daily_draw_view', {
        card_name:    card.name,
        card_slug:    card.slug,
        date_utc:     dateStr,
        reveal_mode:  isRevealed ? 'post_reveal' : 'pre_reveal',
      });
    }
  </script>
</Layout>
