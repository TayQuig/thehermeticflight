---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="What's Your Aerial Tarot Archetype? | The Hermetic Flight"
	description="Discover your unique tarot archetype. Twenty questions, five minutes, one revelation about how you're wired to receive wisdom through the cards."
>
	<main class="w-full min-h-screen flex flex-col relative z-10">
		
		<!-- Minimal Header -->
		<header class="w-full py-6 px-6 flex justify-center">
			<a href="/" class="group flex items-center gap-3">
				<img src="/images/logo.png" alt="The Hermetic Flight" class="w-10 h-10 rounded-full opacity-80 group-hover:opacity-100 transition-opacity" />
				<span class="font-serif text-hermetic-gold/60 text-sm tracking-[0.2em] uppercase group-hover:text-hermetic-gold transition-colors">The Hermetic Flight</span>
			</a>
		</header>

		<!-- Quiz Embed Container -->
		<div class="w-full max-w-4xl mx-auto px-4 pb-8">
			<iframe 
				data-tally-src="https://tally.so/embed/aQ5Gg9?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1" 
				loading="lazy" 
				width="100%" 
				height="566" 
				frameborder="0" 
				marginheight="0" 
				marginwidth="0" 
				title="What's Your Aerial Tarot Archetype?"
			></iframe>
		</div>

	</main>

	<!-- Tally Embed Script -->
	<script is:inline>
		var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
	</script>

	<!-- Form Submission Redirect -->
	<script is:inline>
		window.addEventListener('message', function(e) {
			if (e.data && (e.data.event === 'Tally.FormSubmit' || e.data.type === 'tally.form.submit')) {
				setTimeout(function() {
					window.location.href = 'https://thehermeticflight.com/thank-you';
				}, 500);
			}
		});
	</script>

</Layout>
